# Vercel + Neon Deployment Configuration
# For NBV CRM Application

# Environment Settings
NODE_ENV=production
NEXT_PUBLIC_API_URL=https://your-project.vercel.app

# ============================================
# DATABASE - NEON POSTGRESQL
# ============================================
# Get from: https://console.neon.tech
# Connection String Format:
# postgresql://user:password@ep-xxxxx.region.neon.tech/nbv_crm?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-1.neon.tech/nbv_crm?sslmode=require

# Database Connection Pooling (optional, for Neon)
# Use PgBouncer with Neon for better connection management
DATABASE_URL_POOL=postgresql://user:password@ep-xxxxx.us-east-1.neon.tech/nbv_crm?sslmode=require&connect_timeout=10

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your_very_long_jwt_secret_minimum_32_characters_here_change_me
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_minimum_32_characters_here_change_me
JWT_REFRESH_EXPIRATION=30d

SESSION_SECRET=your_session_secret_minimum_32_characters_long_change_me
SESSION_TIMEOUT=3600000

# API Keys
API_KEY=your_api_key_minimum_32_characters_change_me
NEXT_PUBLIC_API_KEY=your_public_api_key_change_me

# ============================================
# CORS & SECURITY
# ============================================
NEXT_PUBLIC_CORS_ORIGIN=https://crm.nextbridgeventures.com,https://admin.nextbridgeventures.com
CORS_CREDENTIALS=true
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE

# ============================================
# EMAIL CONFIGURATION - SENDGRID
# ============================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key_change_me
MAIL_FROM=noreply@nextbridgeventures.com
MAIL_FROM_NAME=NBV CRM

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# MONITORING - SENTRY (Optional)
# ============================================
SENTRY_ENABLED=true
SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_ENVIRONMENT=production

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_NEW_DASHBOARD=true
FEATURE_ADVANCED_REPORTING=true
FEATURE_CUSTOM_FIELDS=true
FEATURE_AUTOMATION=true

# ============================================
# DEBUG (Development Only - Set to false in production)
# ============================================
DEBUG=false
